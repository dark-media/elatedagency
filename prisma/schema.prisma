generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  role           String    @default("creator")
  avatar         String?
  phone          String?
  instagram      String?
  tiktok         String?
  twitter        String?
  onlyfansUrl    String?
  bio            String?
  status         String    @default("pending")
  referralCode   String?   @unique
  referredBy     String?
  contractSigned Boolean   @default(false)
  contractDate   DateTime?
  onboardedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  applications Application[]
  analytics    Analytics[]
  referrals    Referral[]    @relation("referrer")
  referred     Referral[]    @relation("referred")
  messages     Message[]
  contracts    Contract[]
  sessions     Session[]
}

model Application {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  email           String
  phone           String?
  instagram       String?
  tiktok          String?
  twitter         String?
  onlyfansUrl     String?
  currentEarnings String?
  subscriberCount String?
  contentType     String?
  goals           String?
  experience      String?
  referralCode    String?
  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Contract {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("management")
  status      String   @default("pending")
  signedAt    DateTime?
  startDate   DateTime?
  endDate     DateTime?
  commission  Float    @default(20)
  terms       String?
  signature   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Analytics {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  revenue         Float    @default(0)
  subscribers     Int      @default(0)
  newSubscribers  Int      @default(0)
  messages        Int      @default(0)
  tips            Float    @default(0)
  ppvRevenue      Float    @default(0)
  referralRevenue Float    @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String?
  referredEmail String?
  code         String
  status       String   @default("pending")
  commission   Float    @default(5)
  earnings     Float    @default(0)
  clickCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referrer User  @relation("referrer", fields: [referrerId], references: [id])
  referred User? @relation("referred", fields: [referredId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  sender    String
  content   String
  type      String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BlogPost {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  excerpt         String?
  content         String
  coverImage      String?
  author          String       @default("Elated Agency")
  category        String?
  tags            String?
  published       Boolean      @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  contentPlan     ContentPlan?
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

// === Phase 1: AI Chatbot ===

model ChatSession {
  id           String        @id @default(cuid())
  visitorId    String
  visitorEmail String?
  visitorName  String?
  status       String        @default("active")
  source       String?
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String
  content       String
  createdAt     DateTime    @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id])
}

// === Phase 2: Blog Engine ===

model ContentPlan {
  id             String    @id @default(cuid())
  topic          String
  targetKeywords String?
  status         String    @default("planned")
  blogPostId     String?   @unique
  blogPost       BlogPost? @relation(fields: [blogPostId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// === Phase 3: Email Sequences ===

model EmailQueue {
  id           String    @id @default(cuid())
  to           String
  subject      String
  htmlContent  String
  status       String    @default("pending")
  scheduledFor DateTime
  sentAt       DateTime?
  error        String?
  campaignType String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EmailSequenceState {
  id           String   @id @default(cuid())
  email        String
  campaignType String
  currentStep  Int      @default(0)
  completed    Boolean  @default(false)
  optedOut     Boolean  @default(false)
  startedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([email, campaignType])
}

// === Phase 4: Lead Discovery ===

model Prospect {
  id              String             @id @default(cuid())
  platform        String
  platformUserId  String?
  username        String
  displayName     String?
  profileUrl      String?
  followerCount   Int?
  bio             String?
  discoveredFrom  String?
  postContent     String?
  postUrl         String?
  score           Int                @default(0)
  status          String             @default("new")
  email           String?
  outreachStep    Int                @default(0)
  lastContactedAt DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  outreachMessages OutreachMessage[]

  @@unique([platform, username])
}

model DiscoveryLog {
  id               String   @id @default(cuid())
  platform         String
  query            String
  resultsFound     Int      @default(0)
  prospectsCreated  Int      @default(0)
  createdAt        DateTime @default(now())
}

// === Phase 5: Outreach ===

model OutreachMessage {
  id         String    @id @default(cuid())
  prospectId String
  channel    String
  subject    String?
  content    String
  step       Int
  status     String    @default("pending")
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id])
}
