generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  role           String    @default("creator")
  avatar         String?
  phone          String?
  instagram      String?
  tiktok         String?
  twitter        String?
  onlyfansUrl    String?
  bio            String?
  status         String    @default("pending")
  referralCode   String?   @unique
  referredBy     String?
  contractSigned Boolean   @default(false)
  contractDate   DateTime?
  onboardedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  applications Application[]
  analytics    Analytics[]
  referrals    Referral[]    @relation("referrer")
  referred     Referral[]    @relation("referred")
  messages     Message[]
  contracts    Contract[]
  sessions     Session[]
}

model Application {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  email           String
  phone           String?
  instagram       String?
  tiktok          String?
  twitter         String?
  onlyfansUrl     String?
  currentEarnings String?
  subscriberCount String?
  contentType     String?
  goals           String?
  experience      String?
  referralCode    String?
  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Contract {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("management")
  status      String   @default("pending")
  signedAt    DateTime?
  startDate   DateTime?
  endDate     DateTime?
  commission  Float    @default(20)
  terms       String?
  signature   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Analytics {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  revenue         Float    @default(0)
  subscribers     Int      @default(0)
  newSubscribers  Int      @default(0)
  messages        Int      @default(0)
  tips            Float    @default(0)
  ppvRevenue      Float    @default(0)
  referralRevenue Float    @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String?
  referredEmail String?
  code         String
  status       String   @default("pending")
  commission   Float    @default(5)
  earnings     Float    @default(0)
  clickCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referrer User  @relation("referrer", fields: [referrerId], references: [id])
  referred User? @relation("referred", fields: [referredId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  sender    String
  content   String
  type      String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String   @default("Elated Agency")
  category    String?
  tags        String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}
